# Database
DATABASE_URL=sqlite:///./ecrm.db

# Security (REQUIRED - generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=your-random-secret-key-here

# JWT Token expiry in minutes (default: 120 = 2 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=120

# CORS Origins (comma-separated, no spaces after commas)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
